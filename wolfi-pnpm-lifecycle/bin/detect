#!/usr/bin/env python3
import os
import sys

def main():
    if len(sys.argv) < 3:
        sys.exit(100)
        
    build_plan_path = sys.argv[2]
    working_dir = "/workspace"
    
    project_path = working_dir
    custom_path = os.environ.get("BP_NODE_PROJECT_PATH", "")
    if custom_path:
        project_path = os.path.normpath(os.path.join(working_dir, custom_path))

    env_type = os.environ.get("BP_NODE_PROJECT_TYPE", "").lower()
    lockfile_path = os.path.join(project_path, "pnpm-lock.yaml")

    if env_type != "pnpm" and not os.path.exists(lockfile_path):
        sys.exit(100)

    output = "[[provides]]\nname = \"node_modules\"\n\n[[requires]]\nname = \"node\"\n\n[[requires]]\nname = \"pnpm\"\n"
    
    with open(build_plan_path, 'w') as f:
        f.write(output)

if __name__ == "__main__":
    main()
